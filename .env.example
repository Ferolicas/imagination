# ─────────────────────────────────────────────────────────────
# Imagination — plantilla de entorno (SIN valores reales)
# El .env real vive SOLO en /var/www/imagination/.env del VPS.
# Nunca commitear el .env (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=production
PORT=4003
APP_URL=https://imagination.olcas.app
AUTH_SECRET=                       # openssl rand -base64 32

# ── Base de datos (PostgreSQL nativo del VPS) ──
DATABASE_URL=postgresql://imagination_user:CAMBIAR@localhost:5432/imagination_db

# ── Redis (cola / rate-limit / caché / kill switch) ──
REDIS_URL=redis://localhost:6379

# ── Motores de imagen ──
# Gratis
POLLINATIONS_BASE=https://image.pollinations.ai
SWARM_LOCAL_URL=http://100.127.199.56:7801    # SwarmUI (RTX 4080) por Tailscale
SWARM_QUEUE_URL=http://100.127.199.56:7802    # daemon de cola por Tailscale
# Pago
OPENAI_API_KEY=

# ── Prompt enhancer (LLM) ──
GROQ_API_KEY=                      # tier gratis (Llama)
ANTHROPIC_API_KEY=                 # tier pago (Claude Haiku)

# ── Pagos (Stripe) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ── Email transaccional (Resend) ──
RESEND_API_KEY=
EMAIL_FROM="Imagination <no-reply@olcas.app>"

# ── Anti-abuso / kill switch ──
KILL_SWITCH=off                    # on = pausa generaciones del tier gratis
FREE_WELCOME_CREDITS=30            # créditos de bienvenida (UNA sola vez)
FREE_DAILY_CAP=10                  # tope diario de generaciones gratis por usuario
MAX_FREE_ACCOUNTS_PER_IP=2         # cuentas gratis por IP/día
DAILY_POLLINATIONS_CAP=2000        # umbral diario de llamadas a Pollinations
DAILY_OPENAI_BUDGET_EUR=20         # umbral diario de gasto OpenAI (kill switch)
